# List of target health endpoints separated by commas
BACKEND_URLS_RAW="http://localhost:8000/health,https://your-production-app.onrender.com/health"

# Ping interval bounds in minutes (default every 10 to 14 minutes)
PING_INTERVAL_MIN=10
PING_INTERVAL_MAX=14

# HTTP timeouts and retry rules
REQUEST_TIMEOUT_SEC=10
MAX_RETRIES=3
BACKOFF_FACTOR=2.0

# Alert Webhook for downtime notifications (Slack / Discord webhook URL)
ALERT_WEBHOOK_URL=""
CONSECUTIVE_FAILURE_ALERT_THRESHOLD=5

# Secret auth token sent in X-Keep-Warm-Token header to bypass frontend rate limits
KEEP_WARM_TOKEN=""
